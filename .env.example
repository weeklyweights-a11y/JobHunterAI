# Copy to .env and fill values as needed.
# cp .env.example .env

# Only needed if you select the Gemini (Google) LLM provider in the dashboard.
# GOOGLE_API_KEY=

# Only needed if you select OpenAI (e.g. GPT-4o-mini) in the dashboard.
# OPENAI_API_KEY=

# Only needed if you select Anthropic (Claude) in the dashboard.
# ANTHROPIC_API_KEY=

# Ollama runs locally and does not require an API key in .env.
