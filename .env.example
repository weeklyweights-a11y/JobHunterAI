# Copy to .env and fill values as needed.
# cp .env.example .env

# Windows / Playwright: always start the app with `python run.py` (sets Proactor loop).
# Uvicorn reload breaks Playwright in the child process; default is reload off.
# JOBHUNTER_RELOAD=true

# If port 8000 is already in use: JOBHUNTER_PORT=8001

# --- Gemini: AI Studio (default) vs Vertex AI (GCP billing) ---
# Default: AI Studio API key (GOOGLE_API_KEY) + generativelanguage.googleapis.com
# For Vertex (separate quotas, your Cloud billing):
# JOBHUNTER_GEMINI_BACKEND=vertex
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Must be the Project ID (IAM & Admin → Settings), not the display name. Example: display name
# "JobHunter" can still have project id gen-lang-client-0585672535 — put the id here.
# GOOGLE_CLOUD_LOCATION=us-central1
# Vertex model id (default in code: gemini-2.5-flash). List what your project can use:
#   python scripts/list_vertex_models.py
# If you see 404, pick a line’s “short id” from that script (not gemini-1.5-flash if it’s missing).
# JOBHUNTER_VERTEX_MODEL=gemini-2.5-flash
# Auth: gcloud auth application-default login   OR   GOOGLE_APPLICATION_CREDENTIALS=/path/sa.json
# If you see invalid_grant / RefreshError: revoke and re-login ADC:
#   gcloud auth application-default revoke
#   gcloud auth application-default login
# Optional: try REST instead of gRPC (same creds):
# JOBHUNTER_VERTEX_API_TRANSPORT=rest
# If Vertex returns 403 SERVICE_DISABLED, enable the API (once per project):
#   gcloud services enable aiplatform.googleapis.com --project=YOUR_PROJECT_ID
# Blank browser + 403 in the log = LLM never runs; fix API/auth first.
# Vertex also requires billing on the GCP project (BILLING_DISABLED if missing):
#   https://console.developers.google.com/billing/enable?project=YOUR_PROJECT_ID
# To avoid GCP entirely: comment out JOBHUNTER_GEMINI_BACKEND=vertex and use GOOGLE_API_KEY (AI Studio).
# Optional: skip the one-call Vertex preflight before opening the browser:
# JOBHUNTER_VERTEX_PREFLIGHT=false

# Gemini model (AI Studio path only, unless JOBHUNTER_VERTEX_MODEL unset — then shared fallback name).
# JOBHUNTER_GEMINI_MODEL=gemini-2.0-flash

# Connect browser-use to YOUR Chrome (logged-in LinkedIn, etc.):
# 1) Close Chrome, then start it with remote debugging, e.g.
#    "C:\Program Files\Google\Chrome\Application\chrome.exe" --remote-debugging-port=9222
# 2) Set:
# JOBHUNTER_CDP_URL=http://127.0.0.1:9222
# Or let browser-use launch Chrome with debugging (path to chrome.exe):
# JOBHUNTER_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Optional: use Playwright Chromium with a real profile (fragile; prefer CDP above).
# JOBHUNTER_USE_CHROME_PROFILE=true
# CHROME_USER_DATA_DIR=...
# CHROME_PROFILE_DIRECTORY=Default

# Only needed if you select the Gemini (Google) LLM provider in the dashboard.
# GOOGLE_API_KEY=

# Only needed if you select OpenAI (e.g. GPT-4o-mini) in the dashboard.
# OPENAI_API_KEY=

# Only needed if you select Anthropic (Claude) in the dashboard.
# ANTHROPIC_API_KEY=

# Ollama runs locally and does not require an API key in .env.
