# Copy this file to .env
# cp .env.example .env

# Optional: Only needed if you enable Tier 2 sources (YC, career pages, custom sites)
# LinkedIn and Indeed scraping requires NO API key — it's pure Playwright.
# GOOGLE_API_KEY=your-gemini-key-here
# OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: Override Chrome executable path (auto-detected if not set)
# CHROME_PATH=/usr/bin/google-chrome

# Optional: Set to "true" for hot-reload during development (breaks Playwright on Windows)
# JOBHUNTER_RELOAD=false

# Optional: Force UTF-8 encoding (recommended on Windows)
# PYTHONUTF8=1
